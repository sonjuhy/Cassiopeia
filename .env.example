# ══════════════════════════════════════════════════════════════
#  .env.example — 복사 후 .env 로 저장하고 값을 채워주세요
#  cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── 공통 ───────────────────────────────────────────────────────
PYTHONPATH=.
REDIS_URL=redis://127.0.0.1:6379

# ── Cassiopeia Agent 인증 키 (필수) ─────────────────────────────
# 안전한 무작위 문자열을 사용하세요 (예: openssl rand -hex 32)
ADMIN_API_KEY=your-admin-api-key-here
CLIENT_API_KEY=your-client-api-key-here
# dispatch 메시지 HMAC 서명 키 (권장 — 미설정 시 서명 생략)
# 생성: openssl rand -hex 32
DISPATCH_HMAC_SECRET=your-dispatch-hmac-secret-here

# ── 암호화 키 (필수) ────────────────────────────────────────────
# Fernet 키 생성:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ── LLM 백엔드 설정 ─────────────────────────────────────────────
# 허용값: gemini | claude | local
LLM_BACKEND=gemini

# Google Gemini (LLM_BACKEND=gemini 시 필수)
GEMINI_API_KEY=your-gemini-api-key-here
NLU_LLM_MODEL=gemini-2.0-flash

# Anthropic Claude (LLM_BACKEND=claude 시 필수)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# 로컬 LLM / Ollama (LLM_BACKEND=local 시 필수)
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=llama3.2
# LOCAL_LLM_API_KEY=ollama

# ── NLU 파라미터 ────────────────────────────────────────────────
NLU_CONFIDENCE_THRESHOLD=0.7
NLU_LLM_TEMPERATURE=0.2
USER_TIMEZONE=Asia/Seoul

# ── Redis 접근 제어 (프로덕션 권장) ────────────────────────────
# REDIS_CASSIOPEIA_PASSWORD=strong-password-here
# REDIS_COMMUNITY_PASSWORD=another-strong-password-here

# ── CORS 허용 오리진 (콤마 구분) ────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── 타임아웃 / Circuit Breaker ──────────────────────────────────
RESPONSE_TIMEOUT_SEC=30.0
CB_THRESHOLD=3
CB_WINDOW_SEC=300
HEARTBEAT_VALID_SEC=30

# ── Rate Limiting ───────────────────────────────────────────────
RATE_LIMIT_PER_MIN=20
RATE_LIMIT_WINDOW=60

# ── Sandbox (기본 비활성화) ─────────────────────────────────────
# 활성화하려면 docker 또는 firecracker 로 변경하세요
SANDBOX_RUNTIME=disabled
SANDBOX_API_KEY=your-sandbox-shared-secret-key
# VM_POOL_MIN_READY=2
# VM_POOL_MAX_SIZE=10

# ── Slack 연동 (Slack 에이전트 사용 시) ─────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_CHANNEL=C0XXXXXXXXX

# ── Notion 연동 (Archive 에이전트 사용 시) ──────────────────────
# NOTION_TOKEN=ntn_...
# NOTION_DATABASE_ID=your-database-id-here

# ── Obsidian 연동 (Archive 에이전트 사용 시) ────────────────────
# OBSIDIAN_VAULT_PATH=/path/to/your/vault
