# Communication Agent FastAPI 서버 (장기 실행 Socket Mode 리스너)
# - FastAPI + uvicorn + slack_sdk Socket Mode 기반
# - docker run 으로 에이전트 컨테이너를 트리거하므로 docker-cli 포함
FROM python:3.12-slim

# docker CLI 설치 (에이전트 컨테이너 실행용) + 빌드 도구
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl gcc \
    && curl -fsSL https://download.docker.com/linux/static/stable/x86_64/docker-24.0.9.tgz -o docker.tgz \
    && tar xzvf docker.tgz \
    && mv docker/docker /usr/local/bin/ \
    && rm -rf docker docker.tgz \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 모노리포 구조: 필요한 모듈만 복사
COPY ./agents/__init__.py              /app/agents/__init__.py
COPY ./agents/communication_agent      /app/agents/communication_agent
COPY ./shared_core                     /app/shared_core

# 의존성 설치
RUN pip install --no-cache-dir -r /app/agents/communication_agent/requirements.txt

ENV PYTHONPATH=/app

# FastAPI 헬스체크 포트
EXPOSE 8000

# 진입점: uvicorn 으로 FastAPI 앱 실행 (Socket Mode 자동 시작)
CMD ["python", "-m", "agents.communication_agent.listener_main"]
